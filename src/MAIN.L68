0000E8E6                         20712  TRIGGER_ACH_NEMO:
0000E8E6  48E7 C000              20713      MOVEM.L D0-D1, -(SP)
0000E8EA                         20714      ;already earned? skip
0000E8EA  0CB9 00000001 0000F99E 20715      CMP.L   #1, ACH_UNLOCKED_0
0000E8F4  6700 0034              20716      BEQ     TA_N_DN
0000E8F8                         20717  
0000E8F8                         20718      ;mark earned
0000E8F8  23FC 00000001 0000F99E 20719      MOVE.L  #1, ACH_UNLOCKED_0
0000E902                         20720  
0000E902                         20721      ;start showing the popup
