0000130C                           404  *-----------------------------------------------------------    
0000130C                           405  * Subroutine    : Game
0000130C                           406  * Description   : Game including main GameLoop. GameLoop is like
0000130C                           407  * a while loop in that it runs forever until interupted
0000130C                           408  * (Input, Update, Draw). The Enemies Run at Player Jump to Avoid
0000130C                           409  *-----------------------------------------------------------
0000130C                           410  GAME:
0000130C                           411      ;BSR     PLAY_RUN                ; no run.wav file
0000130C  6100 0256                412      BSR     LOOP_BACKGROUND         ;start music
00001310                           413  GAMELOOP:
00001310                           414      ; Main Gameloop
00001310  6100 FE52                415      BSR     UPDATE_DELTA_TIME       ; Update game time
00001314  6100 FE8C                416      BSR     UPDATE_TIDE             ; Calculate change in the water Y level 
00001318  4EB9 0000CB02            417      JSR     UPDATE_MOONS
0000131E  4EB9 00001EEC            418      JSR     INPUT                   ; Check Keyboard Input
00001324  4EB9 00001F2A            419      JSR     WASD_CHECK_INPUT        ; now check WASD keys
0000132A                           420      
0000132A                           421      ;JSR        PLAYER_MOVEMENT         ; Sets player X and Y movement for this cycle
0000132A                           422      ;BSR     UPDATE                  ; Update positions and points
0000132A                           423      ;jSR        PLYR_UNDERWATER_CHECK   ; if player is above water apply gravity 
0000132A  4EB9 00001FE8            424      JSR     PLAYER_MOVEMENT             ; handle player speed from input
00001330  4EB9 000021BE            425      JSR     PLYR_UNDERWATER_CHECK   ; gravity and jump boost
00001336  6100 00A2                426      BSR     UPDATE                  ; move player based on velocity
0000133A                           427  
0000133A  4EB9 00002132            428      JSR     CLAMP_PLAYER            ; limit player to stay within the screen edges
00001340  4EB9 00002458            429      JSR     MOVE_ALL_ENEMIES        ; Move all 15 fish
00001346  4EB9 0000274A            430      JSR     CHECK_ALL_COLLISIONS    ; Collision check all 15 fish
0000134C                           431      
0000134C                           432      ;pelican stuff
0000134C  4EB9 0000CD6E            433      JSR     UPDATE_PELICAN
00001352  4EB9 0000CE30            434      JSR     CHECK_PELICAN_COLLISION
00001358  4EB9 0000CEFC            435      JSR     CHECK_PELICAN_JUMP
0000135E                           436  
0000135E                           437      ;bone leftovers falling
0000135E  4EB9 0000FB92            438      JSR     UPDATE_LEFTOVERS
00001364                           439  
00001364                           440      ;water splash particles
00001364  4EB9 0000FFD4            441      JSR     UPDATE_SPLASH
0000136A                           442  
0000136A                           443      ;achievements
0000136A  4EB9 0000EBC4            444      JSR     UPDATE_ACHIEVEMENT
00001370  4EB9 0000EB86            445      JSR     UPDATE_AIR_TIME         ;track time spent in the air
00001376  4EB9 0000CC42            446      JSR     CHECK_MOON_COLLISION    ;moon touch achievement
0000137C                           447      
0000137C  6100 000C                448      BSR     DRAW                    ; Draw the Scene
00001380                           449  
00001380                           450      ; Small CPU relief delay        
00001380  7201                     451      MOVE.L  #1,D1
00001382  103C 0017                452      MOVE.B  #23,D0
00001386  4E4F                     453      TRAP    #15                     ;
00001388                           454  
00001388  6086                     455      BRA     GAMELOOP                ; Loop back to GameLoop
