0000130C                           404  *-----------------------------------------------------------    
0000130C                           405  * Subroutine    : Game
0000130C                           406  * Description   : Game including main GameLoop. GameLoop is like
0000130C                           407  * a while loop in that it runs forever until interupted
0000130C                           408  * (Input, Update, Draw). The Enemies Run at Player Jump to Avoid
0000130C                           409  *-----------------------------------------------------------
0000130C                           410  GAME:
0000130C                           411      ;BSR     PLAY_RUN                ; no run.wav file
0000130C  6100 0256                412      BSR     LOOP_BACKGROUND         ;start music
00001310                           413  GAMELOOP:
00001310                           414      ; Main Gameloop
00001310  6100 FE52                415      BSR     UPDATE_DELTA_TIME       ; Update game time
00001314  6100 FE8C                416      BSR     UPDATE_TIDE             ; Calculate change in the water Y level 
00001318  4EB9 0000CB52            417      JSR     UPDATE_MOONS
0000131E  4EB9 00001F3C            418      JSR     INPUT                   ; Check Keyboard Input
00001324  4EB9 00001F7A            419      JSR     WASD_CHECK_INPUT        ; now check WASD keys
0000132A                           420      
0000132A                           421      ;JSR        PLAYER_MOVEMENT         ; Sets player X and Y movement for this cycle
0000132A                           422      ;BSR     UPDATE                  ; Update positions and points
0000132A                           423      ;jSR        PLYR_UNDERWATER_CHECK   ; if player is above water apply gravity 
0000132A  4EB9 00002038            424      JSR     PLAYER_MOVEMENT             ; handle player speed from input
00001330  4EB9 0000220E            425      JSR     PLYR_UNDERWATER_CHECK   ; gravity and jump boost
00001336  6100 00A2                426      BSR     UPDATE                  ; move player based on velocity
0000133A                           427  
0000133A  4EB9 00002182            428      JSR     CLAMP_PLAYER            ; limit player to stay within the screen edges
00001340  4EB9 000024A8            429      JSR     MOVE_ALL_ENEMIES        ; Move all 15 fish
00001346  4EB9 0000279A            430      JSR     CHECK_ALL_COLLISIONS    ; Collision check all 15 fish
0000134C                           431      
0000134C                           432      ;pelican stuff
0000134C  4EB9 0000CDBE            433      JSR     UPDATE_PELICAN
00001352  4EB9 0000CE80            434      JSR     CHECK_PELICAN_COLLISION
00001358  4EB9 0000CF9E            435      JSR     CHECK_PELICAN_JUMP
0000135E                           436  
0000135E                           437      ;bone leftovers falling
0000135E  4EB9 0000FBB4            438      JSR     UPDATE_LEFTOVERS
00001364                           439  
00001364                           440      ;water splash particles
00001364  4EB9 0000FFF6            441      JSR     UPDATE_SPLASH
0000136A                           442  
0000136A                           443      ;achievements
0000136A  4EB9 0000EC16            444      JSR     UPDATE_ACHIEVEMENT
00001370  4EB9 0000EBD8            445      JSR     UPDATE_AIR_TIME         ;track time spent in the air
00001376  4EB9 0000CC92            446      JSR     CHECK_MOON_COLLISION    ;moon touch achievement
0000137C                           447      
0000137C  6100 000C                448      BSR     DRAW                    ; Draw the Scene
00001380                           449  
00001380                           450      ; Small CPU relief delay        
00001380  7201                     451      MOVE.L  #1,D1
00001382  103C 0017                452      MOVE.B  #23,D0
00001386  4E4F                     453      TRAP    #15                     ;
00001388                           454  
00001388  6086                     455      BRA     GAMELOOP                ; Loop back to GameLoop
0000138A                           456  
0000138A                           457  *-----------------------------------------------------------
0000138A                           458  * Subroutine    : Draw
0000138A                           459  * Description   : Draw Screen
0000138A                           460  *-----------------------------------------------------------
0000138A                           461  DRAW: 
0000138A                           462      ; Enable back buffer
0000138A  103C 005E                463      MOVE.B  #94,        D0
0000138E  4E4F                     464      TRAP    #15
00001390                           465  
00001390                           466      ; Clear the screen
00001390                           467      ;MOVE.B #TC_CURSR_P,D0          ; Set Cursor Position
00001390                           468      ;MOVE.W #$FF00,     D1          ; Clear contents
00001390                           469      ;TRAP    #15                     ; Trap (Perform action)
00001390                           470  
00001390  4EB9 00001850            471      JSR     DRAW_BACKGROUND         ; draw sky
00001396  4EB9 0000CC00            472      JSR     DRAW_MOONS
0000139C  4EB9 0000CF4C            473      JSR     DRAW_PELICAN
000013A2  4EB9 00001714            474      JSR     DRAW_WATER              ; draw water tide
000013A8  4EB9 00001E7C            475      JSR     DRAW_PLYR_DATA          ; Draw Draw Score, HUD, Player X and Y
000013AE  4EB9 00001880            476      JSR     DRAW_SAND               ; Draw Sand
000013B4  4EB9 00006A24            477      JSR     DRAW_PLAYER             ; Draw Player
000013BA  4EB9 0000268E            478      JSR     DRAW_ALL_ENEMIES              ; Draw Enemy
000013C0  4EB9 0000FC1C            479      JSR     DRAW_LEFTOVERS          ; Draw falling bone particles
000013C6  4EB9 00010078            480      JSR     DRAW_SPLASH             ; Draw water splash particles
000013CC  4EB9 0001034E            481      JSR     DRAW_SEAWEED             ; Draw seaweed top layer
000013D2  4EB9 0000EC5A            482      JSR     DRAW_ACHIEVEMENT        ; Draw achievement popup
000013D8  4E75                     483      RTS                             ; Return to subroutine
