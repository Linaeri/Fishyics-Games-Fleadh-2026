0000E952                         20616  ; ---- TRIGGER ROUTINES ----
0000E952                         20617  ; each one checks if already earned, if not it marks it,
0000E952                         20618  ; shows the popup, plays the sound and saves to file.
0000E952                         20619  ; they all work the same way just with different IDs
0000E952                         20620  
0000E952                         20621  ;ate a clownfish
0000E952                         20622  TRIGGER_ACH_NEMO:
0000E952  48E7 C000              20623      MOVEM.L D0-D1, -(SP)
0000E956                         20624      ;already earned? skip
0000E956  0CB9 00000001 0000FBF0 20625      CMP.L   #1, ACH_UNLOCKED_0
0000E960  6700 0034              20626      BEQ     TA_N_DN
0000E964                         20627  
0000E964                         20628      ;mark earned
0000E964  23FC 00000001 0000FBF0 20629      MOVE.L  #1, ACH_UNLOCKED_0
0000E96E                         20630  
0000E96E                         20631      ;start showing the popup
0000E96E  23FC 00000000 0000FC28 20632      MOVE.L  #0, ACH_CURRENT_ID
0000E978  23FC 00000BB8 0000FC24 20633      MOVE.L  #ACH_DISPLAY_TIME, ACH_TIMER
0000E982  23FC 00000001 0000FC20 20634      MOVE.L  #1, ACH_SHOWING
0000E98C                         20635  
0000E98C                         20636      ;play the achievement jingle
0000E98C  4EB9 0000F65C          20637      JSR     PLAY_ACH_SND
0000E992                         20638  
0000E992                         20639      ;save to file
0000E992  6100 0C48              20640      BSR     SAVE_ACHIEVEMENTS
0000E996                         20641  
0000E996                         20642  TA_N_DN:
0000E996  4CDF 0003              20643      MOVEM.L (SP)+, D0-D1
0000E99A  4E75                   20644      RTS
0000E99C                         20645  
0000E99C                         20646  ;ran into the pelican (either we ate it or it ate us)
