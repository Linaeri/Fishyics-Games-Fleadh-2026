0000E8BA  23FC 00000BB8 0000F9B0 20708      MOVE.L  #ACH_DISPLAY_TIME, ACH_TIMER
0000E8C4  23FC 00000001 0000F9AC 20709      MOVE.L  #1, ACH_SHOWING
