0000E99C  48E7 C000              20648      MOVEM.L D0-D1, -(SP)
0000E9A0                         20649      ;already earned? skip
0000E9A0  0CB9 00000001 0000FBF4 20650      CMP.L   #1, ACH_UNLOCKED_1
0000E9AA  6700 0034              20651      BEQ     TA_P_DN
