000015BE                           730  *-----------------------------------------------------------
000015BE                           731  * Subroutine    : Collision Check
000015BE                           732  * Description   : Axis-Aligned Bounding Box Collision Detection
000015BE                           733  * Algorithm checks for overlap on the 4 sides of the Player and 
000015BE                           734  * Enemy rectangles
000015BE                           735  * PLAYER_X <= ENEMY_X + ENEMY_W &&
000015BE                           736  * PLAYER_X + PLAYER_W >= ENEMY_X &&
000015BE                           737  * PLAYER_Y <= ENEMY_Y + ENEMY_H &&
000015BE                           738  * PLAYER_H + PLAYER_Y >= ENEMY_Y
000015BE                           739  *-----------------------------------------------------------
000015BE                           740  COLLISION:
000015BE  6100 FE68                741      BSR     PLAY_OPPS               ; Play Opps Wav
000015C2  23FC 00000000 00001690   742      MOVE.L  #00, PLAYER_SCORE       ; Reset Player Score
000015CC  4E75                     743      RTS                             ; Return to subroutine
000015CE                           744  
000015CE                           745  *-----------------------------------------------------------
000015CE                           746  * Subroutine    : EXIT
000015CE                           747  * Description   : Exit message and End Game
000015CE                           748  *-----------------------------------------------------------
000015CE                           749  EXIT:
000015CE                           750      ; Show if Exiting is Running
000015CE  103C 000B                751      MOVE.B  #TC_CURSR_P,D0          ; Set Cursor Position
000015D2  323C 4004                752      MOVE.W  #$4004,     D1          ; Col 40, Row 1
000015D6  4E4F                     753      TRAP    #15                     ; Trap (Perform action)
000015D8  43F9 00001644            754      LEA     EXIT_MSG,   A1          ; Exit
000015DE  303C 000D                755      MOVE    #13,        D0          ; No Line feed
000015E2  4E4F                     756      TRAP    #15                     ; Trap (Perform action)
000015E4  103C 0009                757      MOVE.B  #TC_EXIT,   D0          ; Exit Code
000015E8  4E4F                     758      TRAP    #15                     ; Trap (Perform action)
000015EA                           759  
000015EA                           760  
000015EA                           761  
000015EA  FFFF FFFF                762      SIMHALT
