000013FE                           490  *----------------------------------------------------------- 
000013FE                           491  * Subroutine    : Update
000013FE                           492  * Description   : Main update loop update Player and Enemies
000013FE                           493  *-----------------------------------------------------------
000013FE                           494  UPDATE:
000013FE  48E7 6000                495      MOVEM.L D1-D2, -(SP)
00001402                           496  ;    ; Update the Players Positon based on Velocity and Gravity
00001402                           497  ;    CLR.L   D1                      ; Clear contents of D1 (XOR is faster)
00001402                           498  ;    MOVE.L  PLYR_VELOCITY, D1       ; Fetch Player Velocity
00001402                           499  ;    MOVE.L  PLYR_GRAVITY, D2        ; Fetch Player Gravity
00001402                           500  ;    ADD.L   D2,         D1          ; Add Gravity to Velocity
00001402                           501  ;    MOVE.L  D1,         PLYR_VELOCITY ; Update Player Velocity
00001402                           502  ;    ADD.L   PLAYER_Y,   D1          ; Add Velocity to Player
00001402                           503  ;    MOVE.L  D1,         PLAYER_Y    ; Update Players Y Position 
00001402                           504  
00001402                           505  
00001402                           506      ; Update the Player's Positon based on Velocity and Gravity and DeltaTime
00001402                           507  
00001402                           508  
00001402                           509      ; Position += Velocity * deltaTime -> X VELOCITY
00001402                           510      ;CLR.L   D1                      ; Clear contents of D1
00001402                           511      ;MOVE.L  PLYR_VELOCITY_X, D1        ; Fetch Player Velocity X
00001402                           512      ;MOVE.L  DELTA_TIME, D2         ; Fetch deltaTime
00001402                           513      ;MULS    D2, D1                 ; Multiply Signed velocity * deltaTime
00001402                           514      ;ADD.L   D1, PLAYER_X ;             ; Store it as new player x
00001402                           515      ;MOVE.L  #0, PLYR_VELOCITY_X        ; Reset player x velocity to 0
00001402                           516  
00001402                           517      ; Position += Velocity * deltaTime -> Y VELOCITY
00001402                           518      ;CLR.L   D1                      ; Clear contents of D1
00001402                           519      ;MOVE.L  PLYR_VELOCITY_Y, D1        ; Fetch Player Velocity Y
00001402                           520      ;MOVE.L  DELTA_TIME, D2
00001402                           521      ;MULS    D2, D1 
00001402                           522      ;ADD.L   D1, PLAYER_Y ; 
00001402                           523      ;MOVE.L  #0, PLYR_VELOCITY_Y
00001402                           524      
00001402                           525      ; Move player based on velocity * deltaTime, using the fractional 
00001402                           526      ; position so movement can be slower than 1 pixel per frame
00001402                           527  
00001402                           528      ; X position
00001402  2239 000016AC            529      MOVE.L  PLYR_VELOCITY_X, D1
00001408  2439 0000161A            530      MOVE.L  DELTA_TIME, D2
0000140E  C3C2                     531      MULS    D2, D1                  ; velocity * time
00001410  D3B9 000016A4            532      ADD.L   D1, PLYR_X_SUB          ; add to fractional X
00001416  2239 000016A4            533      MOVE.L  PLYR_X_SUB, D1
0000141C  E081                     534      ASR.L   #8, D1                  ; pixel X
0000141E  23C1 0000169C            535      MOVE.L  D1, PLAYER_X
00001424                           536  
00001424                           537  
00001424                           538      ; Y position
00001424  2239 000016B0            539      MOVE.L  PLYR_VELOCITY_Y, D1
0000142A  2439 0000161A            540      MOVE.L  DELTA_TIME, D2
00001430  C3C2                     541      MULS    D2, D1
00001432  D3B9 000016A8            542      ADD.L   D1, PLYR_Y_SUB
00001438  2239 000016A8            543      MOVE.L  PLYR_Y_SUB, D1
0000143E  E081                     544      ASR.L   #8, D1                  ; pixel Y
00001440  23C1 000016A0            545      MOVE.L  D1, PLAYER_Y
00001446                           546  
00001446  4CDF 0006                547      MOVEM.L (SP)+, D1-D2
0000144A  4E75                     548      RTS                             ; Return to subroutine  
