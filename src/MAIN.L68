00001F10                          1725  INPUT:
00001F10  48E7 E000               1726      MOVEM.L D0-D2, -(SP)
00001F14                          1727      ; Process Input
00001F14  4282                    1728      CLR.L   D2
00001F16  4281                    1729      CLR.L   D1                      ; Clear Data Register
00001F18  103C 0013               1730      MOVE.B  #TC_KEYCODE,D0          ; Listen for Keys
00001F1C  4E4F                    1731      TRAP    #15                     ; Trap (Perform action)
00001F1E  1401                    1732      MOVE.B  D1,         D2          ; Move last key D1 to D2
00001F20  B43C 0000               1733      CMP.B   #00,        D2          ; Key is pressed
00001F24  6700 0012               1734      BEQ     PROCESS_INPUT           ; Process Key
00001F28  4E4F                    1735      TRAP    #15                     ; Trap for Last Key
00001F2A                          1736      ; Check if key still pressed
00001F2A  B23C 00FF               1737      CMP.B   #$FF,       D1          ; Is it still pressed
00001F2E  6700 0008               1738      BEQ     PROCESS_INPUT           ; Process Last Key
00001F32  4CDF 0007               1739      MOVEM.L (SP)+, D0-D2
00001F36  4E75                    1740      RTS                             ; Return to subroutine
00001F38                          1741  
