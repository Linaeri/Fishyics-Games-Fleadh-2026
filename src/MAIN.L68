00001396  4EB9 0000CBB0            472      JSR     DRAW_MOONS
0000139C  4EB9 0001090C            473      JSR     DRAW_PELICAN
000013A2  4EB9 00001714            474      JSR     DRAW_WATER              ; draw water tide
000013A8  4EB9 00001E7C            475      JSR     DRAW_PLYR_DATA          ; Draw Draw Score, HUD, Player X and Y
000013AE  4EB9 00001880            476      JSR     DRAW_SAND               ; Draw Sand
000013B4  4EB9 000069D4            477      JSR     DRAW_PLAYER             ; Draw Player
000013BA  4EB9 0000263E            478      JSR     DRAW_ALL_ENEMIES              ; Draw Enemy
000013C0  4EB9 0000FBFA            479      JSR     DRAW_LEFTOVERS          ; Draw falling bone particles
000013C6  4EB9 00010056            480      JSR     DRAW_SPLASH             ; Draw water splash particles
000013CC  4EB9 0001032C            481      JSR     DRAW_SEAWEED             ; Draw seaweed top layer
