000012B6  D3B9 00001658            384      ADD.L   D1, WTR_Y_SUB           ; down = higher Y
000012BC  2239 00001658            385      MOVE.L  WTR_Y_SUB, D1
000012C2  E081                     386      ASR.L   #8, D1                  ; pixel row
000012C4  23C1 00001654            387      MOVE.L  D1, WTR_CURRENT_Y
000012CA                           388  
