000013BA  4EB9 0000C9BC            477      JSR     DRAW_MOONS
000013C0  4EB9 00010714            478      JSR     DRAW_PELICAN
000013C6  4EB9 00001738            479      JSR     DRAW_WATER              ; draw water tide
