000013DA                           485  *----------------------------------------------------------- 
000013DA                           486  * Subroutine    : Update
000013DA                           487  * Description   : Main update loop update Player and Enemies
000013DA                           488  *-----------------------------------------------------------
000013DA                           489  UPDATE:
000013DA  48E7 6000                490      MOVEM.L D1-D2, -(SP)
000013DE                           491  ;    ; Update the Players Positon based on Velocity and Gravity
000013DE                           492  ;    CLR.L   D1                      ; Clear contents of D1 (XOR is faster)
000013DE                           493  ;    MOVE.L  PLYR_VELOCITY, D1       ; Fetch Player Velocity
000013DE                           494  ;    MOVE.L  PLYR_GRAVITY, D2        ; Fetch Player Gravity
000013DE                           495  ;    ADD.L   D2,         D1          ; Add Gravity to Velocity
000013DE                           496  ;    MOVE.L  D1,         PLYR_VELOCITY ; Update Player Velocity
000013DE                           497  ;    ADD.L   PLAYER_Y,   D1          ; Add Velocity to Player
000013DE                           498  ;    MOVE.L  D1,         PLAYER_Y    ; Update Players Y Position 
000013DE                           499  
000013DE                           500  
000013DE                           501      ; Update the Player's Positon based on Velocity and Gravity and DeltaTime
000013DE                           502  
000013DE                           503  
000013DE                           504      ; Position += Velocity * deltaTime -> X VELOCITY
000013DE                           505      ;CLR.L   D1                      ; Clear contents of D1
000013DE                           506      ;MOVE.L  PLYR_VELOCITY_X, D1        ; Fetch Player Velocity X
000013DE                           507      ;MOVE.L  DELTA_TIME, D2         ; Fetch deltaTime
000013DE                           508      ;MULS    D2, D1                 ; Multiply Signed velocity * deltaTime
000013DE                           509      ;ADD.L   D1, PLAYER_X ;             ; Store it as new player x
000013DE                           510      ;MOVE.L  #0, PLYR_VELOCITY_X        ; Reset player x velocity to 0
000013DE                           511  
000013DE                           512      ; Position += Velocity * deltaTime -> Y VELOCITY
000013DE                           513      ;CLR.L   D1                      ; Clear contents of D1
000013DE                           514      ;MOVE.L  PLYR_VELOCITY_Y, D1        ; Fetch Player Velocity Y
000013DE                           515      ;MOVE.L  DELTA_TIME, D2
000013DE                           516      ;MULS    D2, D1 
000013DE                           517      ;ADD.L   D1, PLAYER_Y ; 
000013DE                           518      ;MOVE.L  #0, PLYR_VELOCITY_Y
000013DE                           519      
000013DE                           520      ; Move player based on velocity * deltaTime, using the fractional 
000013DE                           521      ; position so movement can be slower than 1 pixel per frame
000013DE                           522  
000013DE                           523      ; X position
000013DE  2239 00001688            524      MOVE.L  PLYR_VELOCITY_X, D1
000013E4  2439 000015F6            525      MOVE.L  DELTA_TIME, D2
000013EA  C3C2                     526      MULS    D2, D1                  ; velocity * time
000013EC  D3B9 00001680            527      ADD.L   D1, PLYR_X_SUB          ; add to fractional X
000013F2  2239 00001680            528      MOVE.L  PLYR_X_SUB, D1
000013F8  E081                     529      ASR.L   #8, D1                  ; pixel X
000013FA  23C1 00001678            530      MOVE.L  D1, PLAYER_X
00001400                           531  
00001400                           532  
00001400                           533      ; Y position
00001400  2239 0000168C            534      MOVE.L  PLYR_VELOCITY_Y, D1
00001406  2439 000015F6            535      MOVE.L  DELTA_TIME, D2
0000140C  C3C2                     536      MULS    D2, D1
0000140E  D3B9 00001684            537      ADD.L   D1, PLYR_Y_SUB
00001414  2239 00001684            538      MOVE.L  PLYR_Y_SUB, D1
0000141A  E081                     539      ASR.L   #8, D1                  ; pixel Y
0000141C  23C1 0000167C            540      MOVE.L  D1, PLAYER_Y
00001422                           541  
00001422  4CDF 0006                542      MOVEM.L (SP)+, D1-D2
00001426  4E75                     543      RTS                             ; Return to subroutine  
