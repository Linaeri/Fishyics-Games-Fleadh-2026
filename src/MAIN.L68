00011474  7814                   23723      MOVE.L  #BG_SHARK_W, D4
00011476  4484                   23724      NEG.L   D4                  ; -114
00011478  B684                   23725      CMP.L   D4, D3
0001147A  6D00 0012              23726      BLT     .BG_WRAP_RIGHT
0001147E  2083                   23727      MOVE.L  D3, (A0)
00011480  6000 0034              23728      BRA     .BG_CLAMP_Y
00011484                         23729  
