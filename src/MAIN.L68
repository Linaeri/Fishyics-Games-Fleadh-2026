000012D4  D3B9 0000167C            387      ADD.L   D1, WTR_Y_SUB           ; down = higher Y
000012DA  2239 0000167C            388      MOVE.L  WTR_Y_SUB, D1
000012E0  E081                     389      ASR.L   #8, D1                  ; pixel row
000012E2  23C1 00001678            390      MOVE.L  D1, WTR_CURRENT_Y
000012E8                           391  
