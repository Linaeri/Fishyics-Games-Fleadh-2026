000012AA  E180                     378      ASL.L   #8, D0                  ; fractional Y
000012AC  23C0 00001690            379      MOVE.L  D0, WTR_Y_SUB
000012B2  23FC 00000000 000016A0   380      MOVE.L  #IS_MOVING_FALSE, IS_TIDE_MOVING
000012BC  23FC 00000000 00001698   381      MOVE.L  #0, WTR_CURRENT_TIDE_TIME
