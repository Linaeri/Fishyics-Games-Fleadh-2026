0000132A                           407  *-----------------------------------------------------------    
0000132A                           408  * Subroutine    : Game
0000132A                           409  * Description   : Game including main GameLoop. GameLoop is like
0000132A                           410  * a while loop in that it runs forever until interupted
0000132A                           411  * (Input, Update, Draw). The Enemies Run at Player Jump to Avoid
0000132A                           412  *-----------------------------------------------------------
0000132A                           413  GAME:
0000132A                           414      ;BSR     PLAY_RUN                ; no run.wav file
0000132A  6100 025C                415      BSR     LOOP_BACKGROUND         ;start music
0000132E                           416  GAMELOOP:
0000132E                           417      ; Main Gameloop
0000132E  6100 FE52                418      BSR     UPDATE_DELTA_TIME       ; Update game time
00001332  6100 FE8C                419      BSR     UPDATE_TIDE             ; Calculate change in the water Y level 
00001336  4EB9 0000C956            420      JSR     UPDATE_MOONS
0000133C  4EB9 00001F10            421      JSR     INPUT                   ; Check Keyboard Input
00001342  4EB9 00001F66            422      JSR     WASD_CHECK_INPUT        ; now check WASD keys
00001348                           423      
00001348                           424      ;JSR        PLAYER_MOVEMENT         ; Sets player X and Y movement for this cycle
00001348                           425      ;BSR     UPDATE                  ; Update positions and points
00001348                           426      ;jSR        PLYR_UNDERWATER_CHECK   ; if player is above water apply gravity 
00001348  4EB9 00002024            427      JSR     PLAYER_MOVEMENT             ; handle player speed from input
0000134E  4EB9 000021FA            428      JSR     PLYR_UNDERWATER_CHECK   ; gravity and jump boost
00001354  6100 00A8                429      BSR     UPDATE                  ; move player based on velocity
00001358                           430  
00001358  4EB9 0000216E            431      JSR     CLAMP_PLAYER            ; limit player to stay within the screen edges
0000135E  4EB9 00002494            432      JSR     MOVE_ALL_ENEMIES        ; Move all 15 fish
00001364  4EB9 00002786            433      JSR     CHECK_ALL_COLLISIONS    ; Collision check all 15 fish
0000136A                           434      
0000136A                           435      ;pelican stuff
0000136A  4EB9 0000CBC2            436      JSR     UPDATE_PELICAN
00001370  4EB9 0000CC84            437      JSR     CHECK_PELICAN_COLLISION
00001376  4EB9 0000CD50            438      JSR     CHECK_PELICAN_JUMP
0000137C                           439  
0000137C                           440      ;bone leftovers falling
0000137C  4EB9 0000FE52            441      JSR     UPDATE_LEFTOVERS
00001382                           442  
00001382                           443      ;water splash particles
00001382  4EB9 00010294            444      JSR     UPDATE_SPLASH
00001388                           445  
00001388  4EB9 00006F9A            446      JSR     UPDATE_FLASH
0000138E                           447  
0000138E                           448      ;achievements
0000138E  4EB9 0000EC82            449      JSR     UPDATE_ACHIEVEMENT
00001394  4EB9 0000EC44            450      JSR     UPDATE_AIR_TIME         ;track time spent in the air
0000139A  4EB9 0000CA96            451      JSR     CHECK_MOON_COLLISION    ;moon touch achievement
000013A0                           452      
000013A0  6100 000C                453      BSR     DRAW                    ; Draw the Scene
000013A4                           454  
000013A4                           455      ; Small CPU relief delay        
000013A4  7201                     456      MOVE.L  #1,D1
000013A6  103C 0017                457      MOVE.B  #23,D0
000013AA  4E4F                     458      TRAP    #15                     ;
000013AC                           459  
000013AC  6080                     460      BRA     GAMELOOP                ; Loop back to GameLoop
000013AE                           461  
000013AE                           462  *-----------------------------------------------------------
000013AE                           463  * Subroutine    : Draw
000013AE                           464  * Description   : Draw Screen
000013AE                           465  *-----------------------------------------------------------
000013AE                           466  DRAW: 
000013AE                           467      ; Enable back buffer
000013AE  103C 005E                468      MOVE.B  #94,        D0
000013B2  4E4F                     469      TRAP    #15
000013B4                           470  
000013B4                           471      ; Clear the screen
000013B4                           472      ;MOVE.B #TC_CURSR_P,D0          ; Set Cursor Position
000013B4                           473      ;MOVE.W #$FF00,     D1          ; Clear contents
000013B4                           474      ;TRAP    #15                     ; Trap (Perform action)
000013B4                           475  
000013B4  4EB9 00001874            476      JSR     DRAW_BACKGROUND         ; draw sky
000013BA  4EB9 0000CA04            477      JSR     DRAW_MOONS
000013C0  4EB9 00010BCC            478      JSR     DRAW_PELICAN
000013C6  4EB9 00001738            479      JSR     DRAW_WATER              ; draw water tide
000013CC  4EB9 00001EA0            480      JSR     DRAW_PLYR_DATA          ; Draw Draw Score, HUD, Player X and Y
000013D2  4EB9 000018A4            481      JSR     DRAW_SAND               ; Draw Sand
000013D8  4EB9 00006A5E            482      JSR     DRAW_PLAYER             ; Draw Player
