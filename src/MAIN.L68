00001F38  21C2 1698               1743      MOVE.L  D2,         CURRENT_KEY ; Put Current Key in Memory
00001F3C  0CB8 0000001B 1698      1744      CMP.L   #ESCAPE,    CURRENT_KEY ; Is Current Key Escape
00001F44  6700 F6AC               1745      BEQ     EXIT                    ; Exit if Escape
00001F48                          1746    
