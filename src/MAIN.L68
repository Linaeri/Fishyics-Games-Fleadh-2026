00001192                           288  
00001192  2439 00001616            289      MOVE.L  CURRENT_TIME, D2
00001198  94B9 00001612            290      SUB.L   LAST_TIME, D2  ; Subtract current time from last time to get elapsed milliseconds since
0000119E                           291      
0000119E                           292     * Prevent spikes when game paused etc
0000119E  B4BC 00000032            293      CMP.L  #50, D2      ; if more than or equal to 50 ms pass since last cycle
000011A4  6F00 0004                294      BLE     STORE_DELTA ; skip clamping
000011A8  7432                     295      MOVE.L  #50, D2     ; if current delta time > 50, clamp it to 50 (prevent spikes)
000011AA                           296  
000011AA                           297  STORE_DELTA:                
000011AA                           298  
000011AA  23C2 0000161A            299      MOVE.L  D2, DELTA_TIME
