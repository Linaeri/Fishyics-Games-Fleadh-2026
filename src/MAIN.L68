00001164                           280  UPDATE_DELTA_TIME:
00001164  48E7 E000                281      MOVEM.L D0-D2, -(SP)
00001168  103C 0008                282      MOVE.B  #8, D0          ; Get elapsed milliseconds
0000116C  4E4F                     283      TRAP    #15
0000116E  23C1 000015F2            284      MOVE.L  D1, CURRENT_TIME
00001174                           285  
00001174  2439 000015F2            286      MOVE.L  CURRENT_TIME, D2
0000117A  94B9 000015EE            287      SUB.L   LAST_TIME, D2  ; Subtract current time from last time to get elapsed milliseconds since
00001180                           288      
00001180                           289     * Prevent spikes when game paused etc
00001180  B4BC 00000032            290      CMP.L  #50, D2      ; if more than or equal to 50 ms pass since last cycle
00001186  6F00 0004                291      BLE     STORE_DELTA ; skip clamping
0000118A  7432                     292      MOVE.L  #50, D2     ; if current delta time > 50, clamp it to 50 (prevent spikes)
0000118C                           293  
0000118C                           294  STORE_DELTA:                
0000118C                           295  
0000118C  23C2 000015F6            296      MOVE.L  D2, DELTA_TIME
