000011C0                           306  * Subroutine    : UPDATE_TIDE
000011C0                           307  * Description   : Calculates change in the water Y level 
000011C0                           308  *-----------------------------------------------------------
000011C0                           309  UPDATE_TIDE:
000011C0  48E7 E000                310      MOVEM.L D0-D2, -(SP)
000011C4                           311      ;is tide currently moving?
000011C4  2039 0000168C            312      MOVE.L  IS_TIDE_MOVING, D0
000011CA  B0BC 00000001            313      CMP.L   #IS_MOVING_TRUE, D0
000011D0  6700 008E                314      BEQ     TIDE_IS_MOVING          ; yes -> go move the water
000011D4                           315  
000011D4                           316  *tide not moving, run timer
000011D4                           317  TIDE_IS_WAITING:
000011D4                           318      ; Add deltaTime to the tide wait timer
000011D4  2239 0000161A            319      MOVE.L  DELTA_TIME, D1
000011DA  D3B9 00001684            320      ADD.L   D1, WTR_CURRENT_TIDE_TIME
000011E0                           321  
000011E0                           322      ; Which end are we waiting at?
000011E0                           323      ;   Y >= WTR_TIDE_LOW  -> at bottom, compare HIGH_TIDE_DELAY, next dir = UP
000011E0                           324      ;   Y <  WTR_TIDE_LOW  -> at top,    compare LOW_TIDE_DELAY,  next dir = DOWN
000011E0  2239 00001678            325      MOVE.L  WTR_CURRENT_Y, D1
000011E6  B2BC 00000190            326      CMP.L   #WTR_TIDE_LOW, D1
000011EC  6C00 003A                327      BGE     TIDE_WAIT_AT_LOW
000011F0                           328  
000011F0                           329      ;waiting at HIGH ---
000011F0  2239 00001684            330      MOVE.L  WTR_CURRENT_TIDE_TIME, D1
000011F6  B2BC 00001194            331      CMP.L   #WTR_LOW_TIDE_DELAY, D1
000011FC  6D00 0126                332      BLT     TIDE_DONE               ; delay not elapsed yet
00001200                           333      ; Timer done, start moving DOWN
00001200  23FC 00000001 00001688   334      MOVE.L  #TIDE_DOWN, WTR_TIDE_DIRECTION
0000120A  23FC 00000001 0000168C   335      MOVE.L  #IS_MOVING_TRUE, IS_TIDE_MOVING
00001214  23FC 00000000 00001684   336      MOVE.L  #0, WTR_CURRENT_TIDE_TIME
0000121E  4EB9 000014AA            337      JSR     LOOP_TIDE
00001224  6000 00FE                338      BRA     TIDE_DONE
00001228                           339  
00001228                           340  TIDE_WAIT_AT_LOW:
00001228                           341      ; waiting at LOW ---
00001228  2239 00001684            342      MOVE.L  WTR_CURRENT_TIDE_TIME, D1
0000122E  B2BC 000007D0            343      CMP.L   #WTR_HIGH_TIDE_DELAY, D1
00001234  6D00 00EE                344      BLT     TIDE_DONE               ; delay not elapsed yet
00001238                           345      ; timer done start moving UP
00001238  23FC 00000002 00001688   346      MOVE.L  #TIDE_UP, WTR_TIDE_DIRECTION
00001242  23FC 00000001 0000168C   347      MOVE.L  #IS_MOVING_TRUE, IS_TIDE_MOVING
0000124C  23FC 00000000 00001684   348      MOVE.L  #0, WTR_CURRENT_TIDE_TIME
00001256  4EB9 000014AA            349      JSR     LOOP_TIDE
0000125C  6000 00C6                350      BRA     TIDE_DONE
00001260                           351  
00001260                           352  ;tide is moving
00001260                           353  TIDE_IS_MOVING:
00001260                           354      ; Check direction: DOWN or UP
00001260  2039 00001688            355      MOVE.L  WTR_TIDE_DIRECTION, D0
00001266  B0BC 00000001            356      CMP.L   #TIDE_DOWN, D0
0000126C  6700 005C                357      BEQ     TIDE_GOING_DOWN
00001270                           358      ; otherwise must be TIDE_UP
00001270                           359  
00001270                           360  * Moving UP (Y decreases toward WTR_TIDE_HIGH)
00001270                           361  TIDE_GOING_UP:
00001270  7240                     362      MOVE.L  #WTR_TIDE_SPEED, D1
00001272  2439 0000161A            363      MOVE.L  DELTA_TIME, D2
00001278  C3C2                     364      MULS    D2, D1                  ; speed * time = how far to move
0000127A  93B9 0000167C            365      SUB.L   D1, WTR_Y_SUB           ; up = lower Y
00001280  2239 0000167C            366      MOVE.L  WTR_Y_SUB, D1
00001286  E081                     367      ASR.L   #8, D1                  ; pixel row
00001288  23C1 00001678            368      MOVE.L  D1, WTR_CURRENT_Y
0000128E                           369  
0000128E  B2BC 00000064            370      CMP.L   #WTR_TIDE_HIGH, D1
00001294  6E00 008E                371      BGT     TIDE_DONE               ; not at top yet
00001298                           372      ; clamp and stop
00001298  23FC 00000064 00001678   373      MOVE.L  #WTR_TIDE_HIGH, WTR_CURRENT_Y
000012A2  7064                     374      MOVE.L  #WTR_TIDE_HIGH, D0
000012A4  E180                     375      ASL.L   #8, D0                  ; fractional Y
000012A6  23C0 0000167C            376      MOVE.L  D0, WTR_Y_SUB
000012AC  23FC 00000000 0000168C   377      MOVE.L  #IS_MOVING_FALSE, IS_TIDE_MOVING
000012B6  23FC 00000000 00001684   378      MOVE.L  #0, WTR_CURRENT_TIDE_TIME
000012C0  4EB9 000014B8            379      JSR     STOP_TIDE_SOUND
000012C6  6000 005C                380      BRA     TIDE_DONE
