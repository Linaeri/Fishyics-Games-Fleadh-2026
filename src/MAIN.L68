000012D4                           391      ; clamp and stop
000012D4  23FC 00000190 00001654   392      MOVE.L  #WTR_TIDE_LOW, WTR_CURRENT_Y
000012DE  203C 00000190            393      MOVE.L  #WTR_TIDE_LOW, D0
000012E4  E180                     394      ASL.L   #8, D0                  ; fractional Y
000012E6  23C0 00001658            395      MOVE.L  D0, WTR_Y_SUB
000012EC  23FC 00000000 00001668   396      MOVE.L  #IS_MOVING_FALSE, IS_TIDE_MOVING
000012F6  23FC 00000000 00001660   397      MOVE.L  #0, WTR_CURRENT_TIDE_TIME
