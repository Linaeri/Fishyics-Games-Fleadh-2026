0000138A                           458  * Subroutine    : Draw
0000138A                           459  * Description   : Draw Screen
0000138A                           460  *-----------------------------------------------------------
0000138A                           461  DRAW: 
0000138A                           462      ; Enable back buffer
0000138A  103C 005E                463      MOVE.B  #94,        D0
0000138E  4E4F                     464      TRAP    #15
00001390                           465  
00001390                           466      ; Clear the screen
00001390                           467      ;MOVE.B #TC_CURSR_P,D0          ; Set Cursor Position
00001390                           468      ;MOVE.W #$FF00,     D1          ; Clear contents
00001390                           469      ;TRAP    #15                     ; Trap (Perform action)
00001390                           470  
