00011448                         23700  .BG_MOVE_LOOP:
00011448                         23701      ; X += direction * speed
00011448  2212                   23702      MOVE.L  (A2), D1            ; direction (-1 or 1)
0001144A  7401                   23703      MOVE.L  #BG_SHARK_SPD, D2
0001144C  C5C1                   23704      MULS    D1, D2              ; signed speed
0001144E  2610                   23705      MOVE.L  (A0), D3            ; current X
00011450  D682                   23706      ADD.L   D2, D3              ; new X
00011452                         23707  
00011452                         23708      ; check which edge to test
00011452  B2BC FFFFFFFF          23709      CMP.L   #-1, D1
00011458  6700 001A              23710      BEQ     .BG_CHECK_LEFT
0001145C                         23711  
0001145C                         23712      ; moving right -> check right edge
0001145C  4284                   23713      CLR.L   D4
0001145E  3838 1688              23714      MOVE.W  SCREEN_W, D4
00011462  0684 00000032          23715      ADD.L   #50, D4
00011468  B684                   23716      CMP.L   D4, D3
0001146A  6E00 0018              23717      BGT     .BG_WRAP_TO_LEFT
0001146E  2083                   23718      MOVE.L  D3, (A0)
00011470  6000 0044              23719      BRA     .BG_CLAMP_Y
00011474                         23720  
