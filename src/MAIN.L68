00001330                           410  *-----------------------------------------------------------    
00001330                           411  * Subroutine    : Game
00001330                           412  * Description   : Game including main GameLoop. GameLoop is like
00001330                           413  * a while loop in that it runs forever until interupted
00001330                           414  * (Input, Update, Draw). The Enemies Run at Player Jump to Avoid
00001330                           415  *-----------------------------------------------------------
00001330                           416  GAME:
00001330                           417      ;BSR     PLAY_RUN                ; no run.wav file
00001330  6100 026A                418      BSR     LOOP_BACKGROUND         ;start music
00001334                           419  GAMELOOP:
00001334                           420      ; Main Gameloop
00001334  6100 FE52                421      BSR     UPDATE_DELTA_TIME       ; Update game time
00001338  6100 FE8C                422      BSR     UPDATE_TIDE             ; Calculate change in the water Y level 
0000133C  4EB9 0000C96A            423      JSR     UPDATE_MOONS
00001342  4EB9 00001F24            424      JSR     INPUT                   ; Check Keyboard Input
00001348  4EB9 00001F7A            425      JSR     WASD_CHECK_INPUT        ; now check WASD keys
0000134E                           426      
0000134E                           427      ;JSR        PLAYER_MOVEMENT         ; Sets player X and Y movement for this cycle
0000134E                           428      ;BSR     UPDATE                  ; Update positions and points
0000134E                           429      ;jSR        PLYR_UNDERWATER_CHECK   ; if player is above water apply gravity 
0000134E  4EB9 00002038            430      JSR     PLAYER_MOVEMENT             ; handle player speed from input
00001354  4EB9 0000220E            431      JSR     PLYR_UNDERWATER_CHECK   ; gravity and jump boost
0000135A  6100 00B6                432      BSR     UPDATE                  ; move player based on velocity
0000135E                           433  
0000135E  4EB9 00002182            434      JSR     CLAMP_PLAYER            ; limit player to stay within the screen edges
00001364  4EB9 000024A8            435      JSR     MOVE_ALL_ENEMIES        ; Move all 15 fish
0000136A  4EB9 0000279A            436      JSR     CHECK_ALL_COLLISIONS    ; Collision check all 15 fish
00001370                           437      
00001370                           438      ;pelican stuff
00001370  4EB9 0000CBD6            439      JSR     UPDATE_PELICAN
00001376  4EB9 0000CC98            440      JSR     CHECK_PELICAN_COLLISION
0000137C  4EB9 0000CD64            441      JSR     CHECK_PELICAN_JUMP
00001382                           442  
00001382                           443      ;bone leftovers falling
00001382  4EB9 0000FE66            444      JSR     UPDATE_LEFTOVERS
00001388                           445  
00001388                           446      ;water splash particles
00001388  4EB9 000102A8            447      JSR     UPDATE_SPLASH
0000138E                           448  
0000138E                           449      ;background shark silhouettes
0000138E  4EB9 00011430            450      JSR     UPDATE_BG_SHARKS
00001394                           451  
00001394  4EB9 00006FAE            452      JSR     UPDATE_FLASH
0000139A                           453  
0000139A                           454      ;achievements
0000139A  4EB9 0000EC96            455      JSR     UPDATE_ACHIEVEMENT
000013A0  4EB9 0000EC58            456      JSR     UPDATE_AIR_TIME         ;track time spent in the air
000013A6  4EB9 0000CAAA            457      JSR     CHECK_MOON_COLLISION    ;moon touch achievement
000013AC                           458      
000013AC  6100 000E                459      BSR     DRAW                    ; Draw the Scene
000013B0                           460  
000013B0                           461      ; Small CPU relief delay        
000013B0  7201                     462      MOVE.L  #1,D1
000013B2  103C 0017                463      MOVE.B  #23,D0
000013B6  4E4F                     464      TRAP    #15                     ;
000013B8                           465  
000013B8  6000 FF7A                466      BRA     GAMELOOP                ; Loop back to GameLoop
000013BC                           467  
000013BC                           468  *-----------------------------------------------------------
000013BC                           469  * Subroutine    : Draw
000013BC                           470  * Description   : Draw Screen
000013BC                           471  *-----------------------------------------------------------
000013BC                           472  DRAW: 
000013BC                           473      ; Enable back buffer
000013BC  103C 005E                474      MOVE.B  #94,        D0
000013C0  4E4F                     475      TRAP    #15
000013C2                           476  
000013C2                           477      ; Clear the screen
000013C2                           478      ;MOVE.B #TC_CURSR_P,D0          ; Set Cursor Position
000013C2                           479      ;MOVE.W #$FF00,     D1          ; Clear contents
000013C2                           480      ;TRAP    #15                     ; Trap (Perform action)
000013C2                           481  
000013C2  4EB9 00001888            482      JSR     DRAW_BACKGROUND         ; draw sky
000013C8  4EB9 0000CA18            483      JSR     DRAW_MOONS
000013CE  4EB9 00010BE0            484      JSR     DRAW_PELICAN
000013D4  4EB9 0000174C            485      JSR     DRAW_WATER              ; draw water tide
000013DA  4EB9 000114D4            486      JSR     DRAW_BG_SHARKS          ; Draw background shark silhouettes (behind fish)
000013E0  4EB9 00001EB4            487      JSR     DRAW_PLYR_DATA          ; Draw Draw Score, HUD, Player X and Y
000013E6  4EB9 000018B8            488      JSR     DRAW_SAND               ; Draw Sand
000013EC  4EB9 00006A72            489      JSR     DRAW_PLAYER             ; Draw Player
000013F2  4EB9 0000268E            490      JSR     DRAW_ALL_ENEMIES              ; Draw Enemy
000013F8  4EB9 0000FECE            491      JSR     DRAW_LEFTOVERS          ; Draw falling bone particles
000013FE  4EB9 0001032A            492      JSR     DRAW_SPLASH             ; Draw water splash particles
00001404  4EB9 00010600            493      JSR     DRAW_SEAWEED             ; Draw seaweed top layer
0000140A  4EB9 0000ECDA            494      JSR     DRAW_ACHIEVEMENT        ; Draw achievement popup
00001410  4E75                     495      RTS                             ; Return to subroutine
00001412                           496  
00001412                           497  *----------------------------------------------------------- 
00001412                           498  * Subroutine    : Update
00001412                           499  * Description   : Main update loop update Player and Enemies
00001412                           500  *-----------------------------------------------------------
00001412                           501  UPDATE:
00001412  48E7 6000                502      MOVEM.L D1-D2, -(SP)
00001416                           503  ;    ; Update the Players Positon based on Velocity and Gravity
00001416                           504  ;    CLR.L   D1                      ; Clear contents of D1 (XOR is faster)
00001416                           505  ;    MOVE.L  PLYR_VELOCITY, D1       ; Fetch Player Velocity
00001416                           506  ;    MOVE.L  PLYR_GRAVITY, D2        ; Fetch Player Gravity
00001416                           507  ;    ADD.L   D2,         D1          ; Add Gravity to Velocity
00001416                           508  ;    MOVE.L  D1,         PLYR_VELOCITY ; Update Player Velocity
00001416                           509  ;    ADD.L   PLAYER_Y,   D1          ; Add Velocity to Player
00001416                           510  ;    MOVE.L  D1,         PLAYER_Y    ; Update Players Y Position 
00001416                           511  
00001416                           512  
00001416                           513      ; Update the Player's Positon based on Velocity and Gravity and DeltaTime
00001416                           514  
00001416                           515  
00001416                           516      ; Position += Velocity * deltaTime -> X VELOCITY
00001416                           517      ;CLR.L   D1                      ; Clear contents of D1
00001416                           518      ;MOVE.L  PLYR_VELOCITY_X, D1        ; Fetch Player Velocity X
00001416                           519      ;MOVE.L  DELTA_TIME, D2         ; Fetch deltaTime
00001416                           520      ;MULS    D2, D1                 ; Multiply Signed velocity * deltaTime
00001416                           521      ;ADD.L   D1, PLAYER_X ;             ; Store it as new player x
00001416                           522      ;MOVE.L  #0, PLYR_VELOCITY_X        ; Reset player x velocity to 0
00001416                           523  
00001416                           524      ; Position += Velocity * deltaTime -> Y VELOCITY
00001416                           525      ;CLR.L   D1                      ; Clear contents of D1
00001416                           526      ;MOVE.L  PLYR_VELOCITY_Y, D1        ; Fetch Player Velocity Y
00001416                           527      ;MOVE.L  DELTA_TIME, D2
00001416                           528      ;MULS    D2, D1 
00001416                           529      ;ADD.L   D1, PLAYER_Y ; 
00001416                           530      ;MOVE.L  #0, PLYR_VELOCITY_Y
00001416                           531      
00001416                           532      ; Move player based on velocity * deltaTime, using the fractional 
00001416                           533      ; position so movement can be slower than 1 pixel per frame
00001416                           534  
00001416                           535      ; X position
00001416  2239 000016C0            536      MOVE.L  PLYR_VELOCITY_X, D1
0000141C  2439 0000162E            537      MOVE.L  DELTA_TIME, D2
00001422  C3C2                     538      MULS    D2, D1                  ; velocity * time
00001424  D3B9 000016B8            539      ADD.L   D1, PLYR_X_SUB          ; add to fractional X
0000142A  2239 000016B8            540      MOVE.L  PLYR_X_SUB, D1
00001430  E081                     541      ASR.L   #8, D1                  ; pixel X
00001432  23C1 000016B0            542      MOVE.L  D1, PLAYER_X
00001438                           543  
00001438                           544  
00001438                           545      ; Y position
00001438  2239 000016C4            546      MOVE.L  PLYR_VELOCITY_Y, D1
0000143E  2439 0000162E            547      MOVE.L  DELTA_TIME, D2
00001444  C3C2                     548      MULS    D2, D1
00001446  D3B9 000016BC            549      ADD.L   D1, PLYR_Y_SUB
0000144C  2239 000016BC            550      MOVE.L  PLYR_Y_SUB, D1
00001452  E081                     551      ASR.L   #8, D1                  ; pixel Y
00001454  23C1 000016B4            552      MOVE.L  D1, PLAYER_Y
0000145A                           553  
0000145A  4CDF 0006                554      MOVEM.L (SP)+, D1-D2
0000145E  4E75                     555      RTS                             ; Return to subroutine  
