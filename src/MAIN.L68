0000E898                         20699      ;already earned? skip
0000E898  0CB9 00000001 0000F97C 20700      CMP.L   #1, ACH_UNLOCKED_0
0000E8A2  6700 0034              20701      BEQ     TA_N_DN
0000E8A6                         20702  
0000E8A6                         20703      ;mark earned
0000E8A6  23FC 00000001 0000F97C 20704      MOVE.L  #1, ACH_UNLOCKED_0
0000E8B0                         20705  
0000E8B0                         20706      ;start showing the popup
