000011C6                           309  * Subroutine    : UPDATE_TIDE
000011C6                           310  * Description   : Calculates change in the water Y level 
000011C6                           311  *-----------------------------------------------------------
000011C6                           312  UPDATE_TIDE:
000011C6  48E7 E000                313      MOVEM.L D0-D2, -(SP)
000011CA                           314      ;is tide currently moving?
000011CA  2039 000016A0            315      MOVE.L  IS_TIDE_MOVING, D0
000011D0  B0BC 00000001            316      CMP.L   #IS_MOVING_TRUE, D0
000011D6  6700 008E                317      BEQ     TIDE_IS_MOVING          ; yes -> go move the water
000011DA                           318  
000011DA                           319  *tide not moving, run timer
000011DA                           320  TIDE_IS_WAITING:
000011DA                           321      ; Add deltaTime to the tide wait timer
000011DA  2239 0000162E            322      MOVE.L  DELTA_TIME, D1
000011E0  D3B9 00001698            323      ADD.L   D1, WTR_CURRENT_TIDE_TIME
000011E6                           324  
000011E6                           325      ; Which end are we waiting at?
000011E6                           326      ;   Y >= WTR_TIDE_LOW  -> at bottom, compare HIGH_TIDE_DELAY, next dir = UP
000011E6                           327      ;   Y <  WTR_TIDE_LOW  -> at top,    compare LOW_TIDE_DELAY,  next dir = DOWN
000011E6  2239 0000168C            328      MOVE.L  WTR_CURRENT_Y, D1
000011EC  B2BC 00000190            329      CMP.L   #WTR_TIDE_LOW, D1
000011F2  6C00 003A                330      BGE     TIDE_WAIT_AT_LOW
000011F6                           331  
000011F6                           332      ;waiting at HIGH ---
000011F6  2239 00001698            333      MOVE.L  WTR_CURRENT_TIDE_TIME, D1
000011FC  B2BC 00001194            334      CMP.L   #WTR_LOW_TIDE_DELAY, D1
00001202  6D00 0126                335      BLT     TIDE_DONE               ; delay not elapsed yet
00001206                           336      ; Timer done, start moving DOWN
00001206  23FC 00000001 0000169C   337      MOVE.L  #TIDE_DOWN, WTR_TIDE_DIRECTION
00001210  23FC 00000001 000016A0   338      MOVE.L  #IS_MOVING_TRUE, IS_TIDE_MOVING
0000121A  23FC 00000000 00001698   339      MOVE.L  #0, WTR_CURRENT_TIDE_TIME
00001224  4EB9 000014BE            340      JSR     LOOP_TIDE
0000122A  6000 00FE                341      BRA     TIDE_DONE
0000122E                           342  
0000122E                           343  TIDE_WAIT_AT_LOW:
0000122E                           344      ; waiting at LOW ---
0000122E  2239 00001698            345      MOVE.L  WTR_CURRENT_TIDE_TIME, D1
00001234  B2BC 000007D0            346      CMP.L   #WTR_HIGH_TIDE_DELAY, D1
0000123A  6D00 00EE                347      BLT     TIDE_DONE               ; delay not elapsed yet
0000123E                           348      ; timer done start moving UP
0000123E  23FC 00000002 0000169C   349      MOVE.L  #TIDE_UP, WTR_TIDE_DIRECTION
00001248  23FC 00000001 000016A0   350      MOVE.L  #IS_MOVING_TRUE, IS_TIDE_MOVING
00001252  23FC 00000000 00001698   351      MOVE.L  #0, WTR_CURRENT_TIDE_TIME
0000125C  4EB9 000014BE            352      JSR     LOOP_TIDE
00001262  6000 00C6                353      BRA     TIDE_DONE
00001266                           354  
00001266                           355  ;tide is moving
00001266                           356  TIDE_IS_MOVING:
00001266                           357      ; Check direction: DOWN or UP
00001266  2039 0000169C            358      MOVE.L  WTR_TIDE_DIRECTION, D0
0000126C  B0BC 00000001            359      CMP.L   #TIDE_DOWN, D0
00001272  6700 005C                360      BEQ     TIDE_GOING_DOWN
00001276                           361      ; otherwise must be TIDE_UP
00001276                           362  
00001276                           363  * Moving UP (Y decreases toward WTR_TIDE_HIGH)
00001276                           364  TIDE_GOING_UP:
00001276  7240                     365      MOVE.L  #WTR_TIDE_SPEED, D1
00001278  2439 0000162E            366      MOVE.L  DELTA_TIME, D2
0000127E  C3C2                     367      MULS    D2, D1                  ; speed * time = how far to move
00001280  93B9 00001690            368      SUB.L   D1, WTR_Y_SUB           ; up = lower Y
00001286  2239 00001690            369      MOVE.L  WTR_Y_SUB, D1
0000128C  E081                     370      ASR.L   #8, D1                  ; pixel row
0000128E  23C1 0000168C            371      MOVE.L  D1, WTR_CURRENT_Y
00001294                           372  
00001294  B2BC 00000064            373      CMP.L   #WTR_TIDE_HIGH, D1
0000129A  6E00 008E                374      BGT     TIDE_DONE               ; not at top yet
0000129E                           375      ; clamp and stop
0000129E  23FC 00000064 0000168C   376      MOVE.L  #WTR_TIDE_HIGH, WTR_CURRENT_Y
