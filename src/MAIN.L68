00001EEC                          1720  INPUT:
00001EEC  48E7 E000               1721      MOVEM.L D0-D2, -(SP)
00001EF0                          1722      ; Process Input
00001EF0  4282                    1723      CLR.L   D2
00001EF2  4281                    1724      CLR.L   D1                      ; Clear Data Register
00001EF4  103C 0013               1725      MOVE.B  #TC_KEYCODE,D0          ; Listen for Keys
00001EF8  4E4F                    1726      TRAP    #15                     ; Trap (Perform action)
00001EFA  1401                    1727      MOVE.B  D1,         D2          ; Move last key D1 to D2
00001EFC  B43C 0000               1728      CMP.B   #00,        D2          ; Key is pressed
00001F00  6700 0012               1729      BEQ     PROCESS_INPUT           ; Process Key
00001F04  4E4F                    1730      TRAP    #15                     ; Trap for Last Key
00001F06                          1731      ; Check if key still pressed
00001F06  B23C 00FF               1732      CMP.B   #$FF,       D1          ; Is it still pressed
00001F0A  6700 0008               1733      BEQ     PROCESS_INPUT           ; Process Last Key
00001F0E  4CDF 0007               1734      MOVEM.L (SP)+, D0-D2
00001F12  4E75                    1735      RTS                             ; Return to subroutine
00001F14                          1736  
00001F14                          1737  PROCESS_INPUT:
00001F14  21C2 1674               1738      MOVE.L  D2,         CURRENT_KEY ; Put Current Key in Memory
00001F18  0CB8 0000001B 1674      1739      CMP.L   #ESCAPE,    CURRENT_KEY ; Is Current Key Escape
00001F20  6700 F6AC               1740      BEQ     EXIT                    ; Exit if Escape
00001F24                          1741    
