0000E90C  23FC 00000BB8 0000F9D2 20723      MOVE.L  #ACH_DISPLAY_TIME, ACH_TIMER
0000E916  23FC 00000001 0000F9CE 20724      MOVE.L  #1, ACH_SHOWING
0000E920                         20725  
0000E920                         20726      ;play the achievement jingle
0000E920  4EB9 0000F590          20727      JSR     PLAY_ACH_SND
0000E926                         20728  
0000E926                         20729      ;save to file
0000E926  6100 0BE8              20730      BSR     SAVE_ACHIEVEMENTS
