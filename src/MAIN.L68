00001F2A                          1745  WASD_CHECK_INPUT:
00001F2A  48E7 C000               1746      MOVEM.L D0-D1, -(SP)
00001F2E                          1747  
00001F2E                          1748      ; Assume no movement this frame - clear x and y directions
00001F2E  21FC 00000000 16A0      1749       MOVE.L  #0, PLYR_DIRECTION_X
00001F36  21FC 00000000 169C      1750       MOVE.L  #0, PLYR_DIRECTION_Y
00001F3E                          1751  
00001F3E  103C 0013               1752       MOVE.B #19,D0     
00001F42                          1753  
00001F42  223C 57534144           1754       MOVE.L #'W'<<24+'S'<<16+'A'<<8+'D',D1 ; check for keypress (w,s,a,d)
00001F48                          1755  
00001F48  4E4F                    1756       TRAP   #15
00001F4A                          1757  
00001F4A                          1758      * Vertical Check ------------------------------------------------
00001F4A                          1759      * Up
00001F4A  0801 0018               1760       BTST.L #24,D1     ; test for 'w'
00001F4E                          1761       IF <NE> THEN      ; if 'w'
00001F52  4EB9 00001FAC           1762          JSR     SET_SWIM_UP                     ; if up key pressed, go up  
00001F58                          1763       ENDI
00001F58                          1764  
00001F58                          1765       * Down
00001F58  0801 0010               1766       BTST.L #16,D1     ; test for 's'
00001F5C                          1767       IF <NE> THEN      ; if 's'
00001F60  0801 0018               1768              BTST.L #24,D1     ; test for 'w' again
00001F64                          1769              IF <NE> THEN 
00001F68  4EB9 00001FD4           1770                  JSR     CLEAR_SWIM_VERTICAL     ; If both up and down key are pressed, dont move
00001F6E                          1771              ELSE
00001F72  4EB9 00001FB6           1772                  JSR    SET_SWIM_DOWN            ; otherwise you can swim down
00001F78                          1773  
00001F78                          1774              ENDI
00001F78                          1775       ENDI
00001F78                          1776  
00001F78                          1777      * Horizontal Check ------------------------------------------------
00001F78                          1778      * Left
