00001654                           803  *-----------------------------------------------------------
00001654                           804  * Section       : Tide Water level
00001654                           805  * Description   : Current height of water, time elapsed
00001654                           806  *-----------------------------------------------------------
00001654                           807  
00001654                           808  WTR_CURRENT_Y           DS.L    01  ; Reserve space for water height
00001658                           809  WTR_Y_SUB               DS.L    01  ; Fractional water Y, same idea as PLYR_X_SUB/PLYR_Y_SUB
0000165C                           810  WTR_LAST_TIDE_TIME      DS.L    01  ; Elapsed Miliseconds when the last tide stopped moving
00001660                           811  WTR_CURRENT_TIDE_TIME   DS.L    01  ; Incrementing miliseconds counter since last tide.
00001664                           812  
00001664                           813  WTR_TIDE_DIRECTION      DS.L    01  ; -1 if tide is rising, 0 stationary, 1 lowering
00001668                           814  IS_TIDE_MOVING          DS.L    01  ; 0 = not moving (waiting), 1 = tide is moving
0000166C                           815  
0000166C                           816  ;PLYR_WTR_GRAVITY       DS.L    01  ; reserve space for the gravity out of water
0000166C                           817  ;PLYR_WTR_VELOCITY_Y        DS.L    01  ; The up/downards velocity while out of water
0000166C                           818  ;PLYR_IN_WATER_NOW      DS.L    01  ; 1 if player is underwayer, 0 if player above water
0000166C                           819  ;PLYR_IN_WATER_STATE        DS.L    01  ; 1 = underwater, 0 = above. Saved state from last cycle
0000166C                           820  PLYR_IN_WATER_NOW       DS.L    01  ; 1 if underwater, 0 if in air
00001670                           821  PLYR_IN_WATER_STATE     DS.L    01  ; last frames water state
