00001F24                          1732  INPUT:
00001F24  48E7 E000               1733      MOVEM.L D0-D2, -(SP)
00001F28                          1734      ; Process Input
00001F28  4282                    1735      CLR.L   D2
00001F2A  4281                    1736      CLR.L   D1                      ; Clear Data Register
00001F2C  103C 0013               1737      MOVE.B  #TC_KEYCODE,D0          ; Listen for Keys
00001F30  4E4F                    1738      TRAP    #15                     ; Trap (Perform action)
00001F32  1401                    1739      MOVE.B  D1,         D2          ; Move last key D1 to D2
00001F34  B43C 0000               1740      CMP.B   #00,        D2          ; Key is pressed
00001F38  6700 0012               1741      BEQ     PROCESS_INPUT           ; Process Key
00001F3C  4E4F                    1742      TRAP    #15                     ; Trap for Last Key
00001F3E                          1743      ; Check if key still pressed
00001F3E  B23C 00FF               1744      CMP.B   #$FF,       D1          ; Is it still pressed
00001F42  6700 0008               1745      BEQ     PROCESS_INPUT           ; Process Last Key
00001F46  4CDF 0007               1746      MOVEM.L (SP)+, D0-D2
00001F4A  4E75                    1747      RTS                             ; Return to subroutine
00001F4C                          1748  
00001F4C                          1749  PROCESS_INPUT:
00001F4C  21C2 16AC               1750      MOVE.L  D2,         CURRENT_KEY ; Put Current Key in Memory
00001F50  0CB8 0000001B 16AC      1751      CMP.L   #ESCAPE,    CURRENT_KEY ; Is Current Key Escape
00001F58  6700 F6AC               1752      BEQ     EXIT                    ; Exit if Escape
00001F5C                          1753    
