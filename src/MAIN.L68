000013E4  4EB9 0000FA02            484      JSR     DRAW_LEFTOVERS          ; Draw falling bone particles
000013EA  4EB9 0000FE5E            485      JSR     DRAW_SPLASH             ; Draw water splash particles
000013F0  4EB9 00010134            486      JSR     DRAW_SEAWEED             ; Draw seaweed top layer
000013F6  4EB9 0000EA10            487      JSR     DRAW_ACHIEVEMENT        ; Draw achievement popup
000013FC  4E75                     488      RTS                             ; Return to subroutine
