000015E2                           735  *-----------------------------------------------------------
000015E2                           736  * Subroutine    : Collision Check
000015E2                           737  * Description   : Axis-Aligned Bounding Box Collision Detection
000015E2                           738  * Algorithm checks for overlap on the 4 sides of the Player and 
000015E2                           739  * Enemy rectangles
000015E2                           740  * PLAYER_X <= ENEMY_X + ENEMY_W &&
000015E2                           741  * PLAYER_X + PLAYER_W >= ENEMY_X &&
000015E2                           742  * PLAYER_Y <= ENEMY_Y + ENEMY_H &&
000015E2                           743  * PLAYER_H + PLAYER_Y >= ENEMY_Y
000015E2                           744  *-----------------------------------------------------------
000015E2                           745  COLLISION:
000015E2  6100 FE68                746      BSR     PLAY_OPPS               ; Play Opps Wav
000015E6  23FC 00000000 000016B4   747      MOVE.L  #00, PLAYER_SCORE       ; Reset Player Score
000015F0  4E75                     748      RTS                             ; Return to subroutine
000015F2                           749  
000015F2                           750  *-----------------------------------------------------------
000015F2                           751  * Subroutine    : EXIT
000015F2                           752  * Description   : Exit message and End Game
000015F2                           753  *-----------------------------------------------------------
000015F2                           754  EXIT:
000015F2                           755      ; Show if Exiting is Running
000015F2  103C 000B                756      MOVE.B  #TC_CURSR_P,D0          ; Set Cursor Position
000015F6  323C 4004                757      MOVE.W  #$4004,     D1          ; Col 40, Row 1
000015FA  4E4F                     758      TRAP    #15                     ; Trap (Perform action)
000015FC  43F9 00001668            759      LEA     EXIT_MSG,   A1          ; Exit
00001602  303C 000D                760      MOVE    #13,        D0          ; No Line feed
