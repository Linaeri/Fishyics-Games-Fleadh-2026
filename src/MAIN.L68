000011A2                           303  * Subroutine    : UPDATE_TIDE
000011A2                           304  * Description   : Calculates change in the water Y level 
000011A2                           305  *-----------------------------------------------------------
000011A2                           306  UPDATE_TIDE:
000011A2  48E7 E000                307      MOVEM.L D0-D2, -(SP)
000011A6                           308      ;is tide currently moving?
000011A6  2039 00001668            309      MOVE.L  IS_TIDE_MOVING, D0
000011AC  B0BC 00000001            310      CMP.L   #IS_MOVING_TRUE, D0
000011B2  6700 008E                311      BEQ     TIDE_IS_MOVING          ; yes -> go move the water
000011B6                           312  
000011B6                           313  *tide not moving, run timer
000011B6                           314  TIDE_IS_WAITING:
000011B6                           315      ; Add deltaTime to the tide wait timer
000011B6  2239 000015F6            316      MOVE.L  DELTA_TIME, D1
000011BC  D3B9 00001660            317      ADD.L   D1, WTR_CURRENT_TIDE_TIME
000011C2                           318  
000011C2                           319      ; Which end are we waiting at?
000011C2                           320      ;   Y >= WTR_TIDE_LOW  -> at bottom, compare HIGH_TIDE_DELAY, next dir = UP
000011C2                           321      ;   Y <  WTR_TIDE_LOW  -> at top,    compare LOW_TIDE_DELAY,  next dir = DOWN
000011C2  2239 00001654            322      MOVE.L  WTR_CURRENT_Y, D1
000011C8  B2BC 00000190            323      CMP.L   #WTR_TIDE_LOW, D1
000011CE  6C00 003A                324      BGE     TIDE_WAIT_AT_LOW
000011D2                           325  
000011D2                           326      ;waiting at HIGH ---
000011D2  2239 00001660            327      MOVE.L  WTR_CURRENT_TIDE_TIME, D1
000011D8  B2BC 00001194            328      CMP.L   #WTR_LOW_TIDE_DELAY, D1
000011DE  6D00 0126                329      BLT     TIDE_DONE               ; delay not elapsed yet
000011E2                           330      ; Timer done, start moving DOWN
000011E2  23FC 00000001 00001664   331      MOVE.L  #TIDE_DOWN, WTR_TIDE_DIRECTION
000011EC  23FC 00000001 00001668   332      MOVE.L  #IS_MOVING_TRUE, IS_TIDE_MOVING
000011F6  23FC 00000000 00001660   333      MOVE.L  #0, WTR_CURRENT_TIDE_TIME
00001200  4EB9 00001486            334      JSR     LOOP_TIDE
00001206  6000 00FE                335      BRA     TIDE_DONE
0000120A                           336  
0000120A                           337  TIDE_WAIT_AT_LOW:
0000120A                           338      ; waiting at LOW ---
0000120A  2239 00001660            339      MOVE.L  WTR_CURRENT_TIDE_TIME, D1
00001210  B2BC 000007D0            340      CMP.L   #WTR_HIGH_TIDE_DELAY, D1
00001216  6D00 00EE                341      BLT     TIDE_DONE               ; delay not elapsed yet
0000121A                           342      ; timer done start moving UP
0000121A  23FC 00000002 00001664   343      MOVE.L  #TIDE_UP, WTR_TIDE_DIRECTION
00001224  23FC 00000001 00001668   344      MOVE.L  #IS_MOVING_TRUE, IS_TIDE_MOVING
0000122E  23FC 00000000 00001660   345      MOVE.L  #0, WTR_CURRENT_TIDE_TIME
00001238  4EB9 00001486            346      JSR     LOOP_TIDE
0000123E  6000 00C6                347      BRA     TIDE_DONE
00001242                           348  
00001242                           349  ;tide is moving
00001242                           350  TIDE_IS_MOVING:
00001242                           351      ; Check direction: DOWN or UP
00001242  2039 00001664            352      MOVE.L  WTR_TIDE_DIRECTION, D0
00001248  B0BC 00000001            353      CMP.L   #TIDE_DOWN, D0
0000124E  6700 005C                354      BEQ     TIDE_GOING_DOWN
00001252                           355      ; otherwise must be TIDE_UP
00001252                           356  
00001252                           357  * Moving UP (Y decreases toward WTR_TIDE_HIGH)
00001252                           358  TIDE_GOING_UP:
00001252  7240                     359      MOVE.L  #WTR_TIDE_SPEED, D1
00001254  2439 000015F6            360      MOVE.L  DELTA_TIME, D2
0000125A  C3C2                     361      MULS    D2, D1                  ; speed * time = how far to move
0000125C  93B9 00001658            362      SUB.L   D1, WTR_Y_SUB           ; up = lower Y
00001262  2239 00001658            363      MOVE.L  WTR_Y_SUB, D1
00001268  E081                     364      ASR.L   #8, D1                  ; pixel row
0000126A  23C1 00001654            365      MOVE.L  D1, WTR_CURRENT_Y
00001270                           366  
00001270  B2BC 00000064            367      CMP.L   #WTR_TIDE_HIGH, D1
00001276  6E00 008E                368      BGT     TIDE_DONE               ; not at top yet
0000127A                           369      ; clamp and stop
0000127A  23FC 00000064 00001654   370      MOVE.L  #WTR_TIDE_HIGH, WTR_CURRENT_Y
00001284  7064                     371      MOVE.L  #WTR_TIDE_HIGH, D0
00001286  E180                     372      ASL.L   #8, D0                  ; fractional Y
00001288  23C0 00001658            373      MOVE.L  D0, WTR_Y_SUB
0000128E  23FC 00000000 00001668   374      MOVE.L  #IS_MOVING_FALSE, IS_TIDE_MOVING
00001298  23FC 00000000 00001660   375      MOVE.L  #0, WTR_CURRENT_TIDE_TIME
